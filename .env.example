# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Supabase (server only)
SUPABASE_SECRET_KEY="your-secret-key"

# Stripe (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_secret_key"
STRIPE_VENDOR_MONTHLY_PRICE_ID="price_your_standard_monthly_price_id"
STRIPE_VENDOR_TRANSLATION_MONTHLY_PRICE_ID="price_your_translation_monthly_price_id"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# Optional vendor new-inquiry email
SENDGRID_API_KEY="SG.your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="notifications@your-domain.com"
SENDGRID_FROM_NAME="OffshoreDevelopment.com"
